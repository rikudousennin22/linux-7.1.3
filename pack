find -name "*.ko" -exec aarch64-linux-gnu-strip --strip-debug {} \;
make modules_install INSTALL_MOD_PATH=./Build
mkdir -p ./Build/boot/dtb
# salin semua dtb & dtbo
find arch/arm64/boot/dts/ -type f \( -name "*.dtb" -o -name "*.dtbo" \) -exec cp --parents {} ./Build/boot/dtb/ \;
KVER=$(make kernelrelease)
# buat folder output
mkdir -p ./Build/boot
# salin image dan rename sesuai versi kernel
cp arch/arm64/boot/Image ./Build/boot/vmlinuz-$KVER
cp arch/arm64/boot/Image.gz ./Build/boot/vmlinuz-$KVER.gz 2>/dev/null || true
cp -r Build /mnt/c/Users/Willy/Downloads/Build/
